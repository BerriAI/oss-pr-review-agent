# Slack bot token (xoxb-...) with chat:write and app_mentions:read scopes.
# From your Slack app's "OAuth & Permissions" page.
SLACK_BOT_TOKEN=""

# Slack signing secret. From your Slack app's "Basic Information" → "App Credentials" page.
# Used to verify that incoming events actually came from Slack.
SLACK_SIGNING_SECRET=""

# LiteLLM proxy virtual key (or upstream provider key if hitting a provider directly).
LITELLM_API_KEY=

# Optional: LiteLLM proxy base URL. Defaults to http://0.0.0.0:4000 (local proxy).
# Point at your hosted proxy in prod, e.g. https://your-litellm-proxy.com
LITELLM_API_BASE=

# Optional: model alias to call through the proxy. Defaults to claude-sonnet-4-6.
# Must match a model name your LiteLLM proxy is configured to route.
LITELLM_MODEL=

# GitHub PAT used by the litellm-pr-reviewer skill. Needs public_repo scope (or repo for private).
# Without this the skill fails: GitHub's 60 req/hr unauthenticated quota 403s partway through.
GITHUB_TOKEN=

# Optional: CircleCI project token (CCIPRJ_...) or PAT. When set, the skill splices CircleCI
# failure log tails into its analysis. Without it, only GitHub's check-run summaries are used.
CIRCLECI_TOKEN=

# Optional: hosting platforms set this. Defaults to 8000.
PORT=
